# Copy to .env and fill in values.
# Never commit real secrets.

# --- OpenAI (required) ---
OPENAI_API_KEY=""
# Choose a model that supports `temperature=0` (this app enforces deterministic calls).
OPENAI_MODEL="gpt-4o-mini"

# --- Logging (optional) ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# --- HITL (optional) ---
# If ENABLE_HITL=true, HITL_SQLITE_PATH and RISK_THRESHOLD are required.
ENABLE_HITL="true"
HITL_SQLITE_PATH="./data/hitl.db"
HITL_SQLITE_TABLE="hitl_queue"
RISK_THRESHOLD="0.7"

# Reviewer auth for HITL resolve endpoint
HITL_REVIEW_API_KEY=""

# --- Request log (optional) ---
# Streamlit UI reads from the request log via FastAPI.
REQUEST_LOG_SQLITE_TABLE="request_log"

# --- Streamlit UI (required for running Streamlit) ---
# FastAPI base URL to query (no trailing slash).
AGENTSENTRY_API_URL="http://127.0.0.1:8000"
